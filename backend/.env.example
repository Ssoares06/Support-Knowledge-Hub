# ─── Banco Relacional ─────────────────────────────────────────────────────────
# PostgreSQL (produção):
# DATABASE_URL=postgresql://usuario:senha@host:5432/support_hub
# SQLite (desenvolvimento local — padrão se não definido):
DATABASE_URL=sqlite:///./support_hub.db

# ─── MongoDB (opcional — logs de busca) ──────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGO_DB_NAME=support_hub_logs

# ─── JWT ─────────────────────────────────────────────────────────────────────
SECRET_KEY=troque-esta-chave-por-uma-string-aleatoria-longa
ACCESS_TOKEN_EXPIRE_MINUTES=1440
